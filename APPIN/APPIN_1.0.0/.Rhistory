source("C:/Users/juguibert/Downloads/analyse_effet_operateur.R")
p9
p1
ggsave("fig1_boxplot_operateurs_methodes.png", p1, width = 10, height = 10, dpi = 300)
p2 <- ggplot(df_long, aes(x = Operateur, y = Erreur, fill = Methode)) +
geom_boxplot(alpha = 0.8, position = position_dodge(0.8), width = 0.7) +
geom_hline(yintercept = 0, linetype = "dashed", color = "gray40", linewidth = 0.5) +
scale_fill_manual(values = methode_colors) +
labs(
title = "Comparaison des méthodes d'intégration par opérateur",
x = "Opérateur",
y = "Erreur (%)",
fill = "Méthode"
) +
theme_bw(base_size = 12) +
theme(
legend.position = "top",
plot.title = element_text(face = "bold", size = 14),
axis.text.x = element_text(angle = 45, hjust = 1)
)
p2
ggsave("fig2_comparaison_methodes_operateurs.png", p2, width = 12, height = 6, dpi = 300)
df_summary <- df_long %>%
group_by(Operateur, Methode) %>%
summarise(
Erreur_moyenne = mean(Erreur, na.rm = TRUE),
Erreur_sd = sd(Erreur, na.rm = TRUE),
Erreur_abs_moyenne = mean(abs(Erreur), na.rm = TRUE),
.groups = "drop"
)
p3 <- ggplot(df_summary, aes(x = Methode, y = Operateur, fill = Erreur_moyenne)) +
geom_tile(color = "white", linewidth = 0.5) +
geom_text(aes(label = sprintf("%.1f", Erreur_moyenne)), color = "black", size = 4) +
scale_fill_gradient2(
low = "#2166AC", mid = "white", high = "#B2182B", midpoint = 0,
name = "Erreur\nmoyenne (%)"
) +
labs(
title = "Erreur moyenne d'intégration",
subtitle = "Par opérateur et méthode",
x = "Méthode d'intégration",
y = "Opérateur"
) +
theme_minimal(base_size = 12) +
theme(
plot.title = element_text(face = "bold", size = 14),
axis.text = element_text(size = 11),
panel.grid = element_blank()
)
p3
ggsave("fig3_heatmap_erreur_moyenne.png", p3, width = 8, height = 8, dpi = 300)
p4 <- ggplot(df_summary, aes(x = Methode, y = Operateur, fill = Erreur_abs_moyenne)) +
geom_tile(color = "white", linewidth = 0.5) +
geom_text(aes(label = sprintf("%.1f", Erreur_abs_moyenne)), color = "black", size = 4) +
scale_fill_gradient(
low = "white", high = "#D73027",
name = "Erreur abs.\nmoyenne (%)"
) +
labs(
title = "Erreur absolue moyenne d'intégration",
subtitle = "Par opérateur et méthode (magnitude de l'erreur)",
x = "Méthode d'intégration",
y = "Opérateur"
) +
theme_minimal(base_size = 12) +
theme(
plot.title = element_text(face = "bold", size = 14),
axis.text = element_text(size = 11),
panel.grid = element_blank()
)
p4
ggsave("fig4_heatmap_erreur_absolue.png", p4, width = 8, height = 8, dpi = 300)
p5 <- ggplot(df_long, aes(x = Operateur, y = Erreur, fill = Methode)) +
geom_violin(alpha = 0.6, position = position_dodge(0.9), scale = "width") +
geom_boxplot(width = 0.15, position = position_dodge(0.9), alpha = 0.8, outlier.size = 0.5) +
geom_hline(yintercept = 0, linetype = "dashed", color = "gray40", linewidth = 0.5) +
scale_fill_manual(values = methode_colors) +
labs(
title = "Distribution des erreurs d'intégration",
subtitle = "Violin plots avec boxplots intégrés",
x = "Opérateur",
y = "Erreur (%)",
fill = "Méthode"
) +
theme_bw(base_size = 12) +
theme(
legend.position = "top",
plot.title = element_text(face = "bold", size = 14),
axis.text.x = element_text(angle = 45, hjust = 1)
)
p5
ggsave("fig5_violin_plots.png", p5, width = 14, height = 7, dpi = 300)
p6 <- ggplot(df_long, aes(x = Operateur, y = Metabolite, fill = Erreur)) +
geom_tile(color = "white", linewidth = 0.3) +
facet_wrap(~Methode, ncol = 3) +
scale_fill_gradient2(
low = "#2166AC", mid = "white", high = "#B2182B", midpoint = 0,
name = "Erreur (%)",
limits = c(-50, 50),
oob = squish
) +
labs(
title = "Erreurs d'intégration par métabolite, opérateur et méthode",
x = "Opérateur",
y = "Métabolite"
) +
theme_minimal(base_size = 10) +
theme(
plot.title = element_text(face = "bold", size = 12),
axis.text.x = element_text(angle = 90, hjust = 1, vjust = 0.5, size = 8),
axis.text.y = element_text(size = 7),
strip.background = element_rect(fill = "gray90"),
strip.text = element_text(face = "bold"),
panel.grid = element_blank()
)
p6
ggsave("fig6_heatmap_metabolites.png", p6, width = 14, height = 12, dpi = 300)
df_operateur_summary <- df_long %>%
group_by(Operateur, Methode) %>%
summarise(
Mean = mean(Erreur, na.rm = TRUE),
SD = sd(Erreur, na.rm = TRUE),
SE = SD / sqrt(n()),
.groups = "drop"
)
p7 <- ggplot(df_operateur_summary, aes(x = Operateur, y = Mean, fill = Methode)) +
geom_bar(stat = "identity", position = position_dodge(0.8), width = 0.7, alpha = 0.9) +
geom_errorbar(
aes(ymin = Mean - SE, ymax = Mean + SE),
position = position_dodge(0.8),
width = 0.25
) +
geom_hline(yintercept = 0, linetype = "solid", color = "gray40", linewidth = 0.5) +
scale_fill_manual(values = methode_colors) +
labs(
title = "Erreur moyenne par opérateur et méthode",
subtitle = "Barres d'erreur = erreur standard",
x = "Opérateur",
y = "Erreur moyenne (%)",
fill = "Méthode"
) +
theme_bw(base_size = 12) +
theme(
legend.position = "top",
plot.title = element_text(face = "bold", size = 14),
axis.text.x = element_text(angle = 45, hjust = 1)
)
p7
ggsave("fig7_barplot_erreur_moyenne.png", p7, width = 12, height = 6, dpi = 300)
df_methode_summary <- df_long %>%
group_by(Methode) %>%
summarise(
Mean = mean(Erreur, na.rm = TRUE),
SD = sd(Erreur, na.rm = TRUE),
Mean_Abs = mean(abs(Erreur), na.rm = TRUE),
Median = median(Erreur, na.rm = TRUE),
.groups = "drop"
)
p8a <- ggplot(df_long, aes(x = Methode, y = Erreur, fill = Methode)) +
geom_violin(alpha = 0.6, scale = "width") +
geom_boxplot(width = 0.2, alpha = 0.8) +
geom_hline(yintercept = 0, linetype = "dashed", color = "gray40") +
scale_fill_manual(values = methode_colors) +
labs(title = "Distribution globale", x = "Méthode", y = "Erreur (%)") +
theme_bw(base_size = 12) +
theme(legend.position = "none", plot.title = element_text(face = "bold"))
p8b <- ggplot(df_methode_summary, aes(x = Methode, y = Mean_Abs, fill = Methode)) +
geom_bar(stat = "identity", alpha = 0.9, width = 0.6) +
geom_text(aes(label = sprintf("%.2f", Mean_Abs)), vjust = -0.5, size = 4) +
scale_fill_manual(values = methode_colors) +
labs(title = "Erreur absolue moyenne", x = "Méthode", y = "|Erreur| moyenne (%)") +
theme_bw(base_size = 12) +
theme(legend.position = "none", plot.title = element_text(face = "bold")) +
ylim(0, max(df_methode_summary$Mean_Abs) * 1.2)
p8 <- p8a + p8b +
plot_annotation(title = "Comparaison globale des méthodes d'intégration",
theme = theme(plot.title = element_text(face = "bold", size = 14)))
p8
ggsave("fig8_comparaison_globale_methodes.png", p8, width = 12, height = 5, dpi = 300)
df_variabilite <- df_long %>%
group_by(Methode, Metabolite) %>%
summarise(SD = sd(Erreur, na.rm = TRUE), .groups = "drop")
p9 <- ggplot(df_variabilite, aes(x = Methode, y = SD, fill = Methode)) +
geom_boxplot(alpha = 0.7) +
scale_fill_manual(values = methode_colors) +
labs(
title = "Variabilité inter-opérateur par méthode",
subtitle = "Écart-type des erreurs entre opérateurs pour chaque métabolite",
x = "Méthode",
y = "Écart-type des erreurs (%)"
) +
theme_bw(base_size = 12) +
theme(legend.position = "none", plot.title = element_text(face = "bold", size = 14))
p9
ggsave("fig9_variabilite_inter_operateur.png", p9, width = 8, height = 6, dpi = 300)
